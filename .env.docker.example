# Copy to .env.docker before running:  docker compose --profile app up -d --build
# .env.docker is gitignored — never commit real secrets.

# Internal service DNS for the bundled compose stack — leave as-is (these are the compose service names,
# NOT host localhost:5433/6380).
DATABASE_URL=postgres://opentag:opentag@postgres:5432/opentag
REDIS_URL=redis://redis:6379
PORT=7788

# ── Secrets (REQUIRED — generate strong values: openssl rand -hex 32) ────────
JWT_SECRET=
DAEMON_BOOTSTRAP_KEY=
# One-time admin bootstrap token for POST /api/auth/setup. Clear after first use.
ADMIN_SETUP_TOKEN=

# ── Human auth ────────────────────────────────────────────────────────────────
# DEVELOPMENT ONLY — Leave unset (or false) in production.
# Set to true only for local/dev stacks to enable POST /api/auth/dev-login.
ALLOW_DEV_LOGIN=false

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed browser origins.
# Production: set to your frontend URL(s).  Dev: leave unset (localhost allowed).
# ALLOWED_ORIGIN=https://app.example.com

# ── Rate-limit trust proxy ────────────────────────────────────────────────────
# Set to true ONLY if a controlled reverse proxy rewrites X-Forwarded-For.
# TRUST_PROXY=true

# ── Agent workspace ───────────────────────────────────────────────────────────
# Base dir for agent workspaces, logs, and uploads. Default: ~/.open-tag
# OPEN_TAG_HOME=/data/open-tag
